# Google Service Account Email (from Google Cloud service account JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Google Service Account Private Key (from JSON, including the newlines as \n)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Sheet ID (from the spreadsheet URL)
GOOGLE_SHEET_ID=

# Optional: Google Sheet Tab name (defaults to 'Enquiries')
GOOGLE_SHEET_TAB=Enquiries